# ============================================================
# 都市文娱小说生成系统 - .gitignore
# ============================================================

# 数据文件（版权保护，仅保留目录结构+标记文件）
data/raw/*
data/clean/*
data/sft/*
data/knowledge/*
!data/**/.gitkeep

# RAG 向量数据库（二进制，不追踪）
data/rag/chroma_db/
data/rag/_test_chroma/

# 模型权重
models/base/
models/lora_adapters/
models/lora_adapters_test/
models/merged/
!models/**/.gitkeep

# 模型权重文件（无论在哪）
*.bin
*.safetensors
*.gguf
*.pt
*.pth
*.ckpt
*.tar.gz

# 环境变量
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 训练日志
wandb/
logs/
lightning_logs/

# 生成输出
output/
*.txt.generated

# OS
.DS_Store
Thumbs.db
